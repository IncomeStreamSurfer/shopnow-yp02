---
const navLinks = [
  { href: "/shop", label: "Shop" },
  { href: "/collections", label: "Collections" },
  { href: "/about", label: "About" },
  { href: "/blog", label: "Journal" },
  { href: "/contact", label: "Contact" },
];
const path = Astro.url.pathname;
---
<header class="sticky top-0 z-40 border-b border-[var(--color-line)] bg-[var(--color-paper)]/85 backdrop-blur">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-6 py-4">
    <a href="/" class="flex items-center gap-2 font-serif text-2xl font-semibold tracking-tight">
      <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-[var(--color-ink)] text-[var(--color-accent)]">◉</span>
      ShopNow
    </a>
    <nav class="hidden items-center gap-8 text-sm font-medium md:flex">
      {navLinks.map((l) => (
        <a href={l.href} class={`transition hover:text-[var(--color-accent)] ${path === l.href ? "text-[var(--color-accent)]" : "text-[var(--color-ink)]/80"}`}>{l.label}</a>
      ))}
    </nav>
    <div class="flex items-center gap-3">
      <a href="/shop" class="hidden text-sm text-[var(--color-ink)]/70 transition hover:text-[var(--color-accent)] sm:inline">Search</a>
      <a href="/cart" class="inline-flex items-center gap-2 rounded-full border border-[var(--color-ink)] bg-[var(--color-ink)] px-4 py-2 text-sm font-semibold text-[var(--color-paper)] transition hover:bg-[var(--color-accent)] hover:border-[var(--color-accent)]">
        Cart <span id="cart-count" class="inline-flex h-5 min-w-5 items-center justify-center rounded-full bg-[var(--color-accent-2)] px-1.5 text-[11px] font-bold text-[var(--color-ink)]">0</span>
      </a>
    </div>
  </div>
</header>
